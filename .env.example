# Kopieren nach .env im gleichen Ordner wie app.py und Werte eintragen.
# Die Datei .env wird von Git ignoriert.

# --- Flask (für echte Nutzung setzen) ---
# FLASK_SECRET_KEY=…   # z. B. python -c "import secrets; print(secrets.token_hex(32))"
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
# FLASK_DEBUG=false

# =============================================================================
# Gmail SMTP (Lehrer-E-Mails bei Laden-Käufen)
# =============================================================================
# 1) Google-Konto: 2-Faktor-Authentifizierung einschalten (Pflicht für App-Passwörter).
# 2) https://myaccount.google.com/apppasswords — App-Passwort erzeugen (16 Zeichen).
# 3) Unten deine Gmail-Adresse + das App-Passwort eintragen (NICHT dein normales Login-Passwort).
#
# Variante A — empfohlen (Port 587, STARTTLS, Standard in mailer.py):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=deine.adresse@gmail.com
SMTP_PASSWORD=dein-app-passwort
SMTP_FROM=deine.adresse@gmail.com
# SMTP_USE_SSL und SMTP_STARTTLS weglassen (Defaults: SSL aus, STARTTLS an)
#
# Variante B — alternativ Port 465 mit direktem SSL:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USE_SSL=1
# SMTP_STARTTLS=0
# SMTP_USER=deine.adresse@gmail.com
# SMTP_PASSWORD=hier-app-passwort
# SMTP_FROM=deine.adresse@gmail.com
#
# Google Workspace (eigene Domain): gleicher Host, USER/FROM = deine@schule.de
#
# SMTP_TIMEOUT=30
